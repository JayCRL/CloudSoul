# Continuum server 配置示例。复制为 .env 并填写。
CONTINUUM_LISTEN_ADDR=:8088
CONTINUUM_DB_DSN=postgres://continuum:continuum@localhost:5432/continuum?sslmode=disable
CONTINUUM_BEARER_TOKEN=change-me-to-a-long-random-token

# handoff 压缩 / 习惯提炼用的 AI endpoint（复用你现有中转，留空则禁用相关功能）
CONTINUUM_AI_BASE_URL=
CONTINUUM_AI_TOKEN=
CONTINUUM_AI_MODEL=claude-haiku-4-5-20251001
